{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "builds": [
    { "src": "api/*.ts", "use": "@vercel/node" },
    { "src": "api/intelligence/*.ts", "use": "@vercel/node" }
  ],
  "functions": {
    "api/*.ts": {
      "maxDuration": 60
    },
    "api/intelligence/*.ts": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}

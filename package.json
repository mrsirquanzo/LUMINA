{
  "name": "lumina",
  "private": true,
  "version": "0.1.0",
  "description": "Biotech target/asset diligence dashboard with a grounded, glass-box research agent (Sonny) that produces conclusion-first GO/WATCH/NO-GO dossiers.",
  "license": "MIT",
  "author": "Quan Ho (@mrsirquanzo)",
  "type": "module",
  "homepage": "https://github.com/mrsirquanzo/LUMINA#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrsirquanzo/LUMINA.git"
  },
  "keywords": [
    "biotech",
    "due-diligence",
    "intelligence-dashboard",
    "research-agent",
    "react",
    "typescript"
  ],
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:server": "node dist/server/index.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@mrsirquanzo/sonny-core": "^0.1.0",
    "@mrsirquanzo/sonny-mcp-gateway": "^0.1.0",
    "@mrsirquanzo/sonny-shared": "^0.1.0",
    "@tanstack/react-query": "^5.90.12",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "autoprefixer": "^10.4.22",
    "cheerio": "^1.1.2",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "esbuild": "0.25.12",
    "express": "^5.2.1",
    "framer-motion": "^12.23.25",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.556.0",
    "marked": "^17.0.1",
    "multer": "^2.0.2",
    "openai": "^6.10.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.5.1",
    "remark-gfm": "^4.0.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.15",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.15"
  }
}

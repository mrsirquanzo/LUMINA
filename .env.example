# ===========================================
# MULTI-MODEL LLM API KEYS
# ===========================================

# Anthropic API Key (Claude Sonnet 4)
# Used by: Clinical Data Analyst, Regulatory Expert
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API Key
# Used by: Financial Analyst
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Perplexity API Key
# Used by: Patent Expert, Market Research Agent
# Get your API key from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ===========================================
# AUTHENTICATION
# ===========================================

# Agent Access Password
# Set a password to protect live agent access
# Default: demo2024 (change this!)
AGENT_ACCESS_PASSWORD=demo2024

# ===========================================
# MCP (MODEL CONTEXT PROTOCOL) - OPTIONAL
# ===========================================

# Enable MCP for real-time data access
# Set to 'true' to enable, 'false' or omit to disable
# Default: false
MCP_ENABLED=false

# Patent Database API Key (Optional)
# For real-time patent search via USPTO, Google Patents APIs
PATENT_API_KEY=your_patent_api_key_here

# Market Data API Key (Optional)
# For real-time market intelligence, news, competitive data
# Recommended: NewsAPI, EvaluatePharma, or similar services
MARKET_DATA_API_KEY=your_market_data_api_key_here

# Financial Data API Key (Optional)
# For SEC filings, stock data, financial analytics
# Recommended: Alpha Vantage, Financial Modeling Prep, or Yahoo Finance API
FINANCIAL_API_KEY=your_financial_api_key_here

# Note: MCP servers for Clinical and Regulatory data use public APIs
# (ClinicalTrials.gov, PubMed, FDA openFDA) that don't require API keys

# ===========================================
# SETUP INSTRUCTIONS
# ===========================================

# 1. Copy this file to .env.local
# 2. Add your actual API keys above
# 3. Never commit .env.local to git (it's already in .gitignore)
# 4. All three API keys are required for the multi-model system to work

# Agent-to-Model Mapping:
# - Clinical Data Analyst → Claude Sonnet 4 (Anthropic)
# - Regulatory Expert → Claude Sonnet 4 (Anthropic)
# - Patent Expert → Perplexity Sonar Pro (Perplexity)
# - Market Research → Perplexity Sonar Pro (Perplexity)
# - Financial Analyst → Gemini 2.0 Flash (Google)

